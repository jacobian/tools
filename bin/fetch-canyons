#!/usr/bin/env -S uv run --script
"""Download canyon trip data from Google Sheets and write to _data/canyons.json."""

import csv
import io
import json
import re
import urllib.request
from datetime import date
from pathlib import Path

SHEET_ID = "1S2Ik2kmfm-CI7mXaWe8nlGlPAGZ3oZ7U0Af9qZoiRRg"
URL = f"https://docs.google.com/spreadsheets/d/{SHEET_ID}/export?format=csv"
OUTPUT = Path(__file__).parent.parent / "_data" / "canyons.json"

MONTH_NAMES = [
    "January", "February", "March", "April", "May", "June",
    "July", "August", "September", "October", "November", "December",
]


def parse_date(raw: str | None) -> date | None:
    """Parse a messy date string into a date object.

    Handles:
      - M/D/YYYY and M/D/YY
      - Ranges like "5/6/24 - 5/12/24" (uses first date)
      - Fuzzy day "M/??/YY" (uses 15th)
      - Missing slash "7/??24" → "7/1524" (M/DYY pattern)
      - Garbled "65??/24" (month from start, year from end, day=15)
    """
    if not raw:
        return None

    s = raw.strip()

    # Ranges → use first date
    if " - " in s:
        s = s.split(" - ")[0].strip()

    # Fuzzy day → 15th
    s = s.replace("??", "15")

    def make(month: int, day: int, year: int) -> date | None:
        if year < 100:
            year += 2000
        try:
            return date(year, month, day)
        except ValueError:
            return None

    # M/D/YYYY
    if m := re.fullmatch(r"(\d{1,2})/(\d{1,2})/(\d{4})", s):
        return make(int(m[1]), int(m[2]), int(m[3]))

    # M/D/YY
    if m := re.fullmatch(r"(\d{1,2})/(\d{1,2})/(\d{2})", s):
        return make(int(m[1]), int(m[2]), int(m[3]))

    # M/DYY — missing slash before 2-digit year (e.g. "7/1524" from "7/??24")
    if m := re.fullmatch(r"(\d{1,2})/(\d{1,2})(\d{2})", s):
        return make(int(m[1]), int(m[2]), int(m[3]))

    # Last resort: valid month from start, 2-digit year from end, day=15
    m_mo = re.match(r"^(1[0-2]|[1-9])", s)
    m_yr = re.search(r"(\d{2})$", s)
    if m_mo and m_yr:
        return make(int(m_mo[1]), 15, int(m_yr[1]))

    return None


def format_dates(raw: str | None) -> tuple[str | None, str]:
    """Return (display_date, sort_date) for a raw date string.

    display_date: "June 2023" or None if unparseable
    sort_date: "YYYY-MM-DD"; "0000-01-01" if unparseable (sorts last when reversed)
    """
    d = parse_date(raw)
    if d is None:
        return None, "0000-01-01"
    return f"{MONTH_NAMES[d.month - 1]} {d.year}", d.strftime("%Y-%m-%d")


def coerce(value: str) -> str | int | float | None:
    if value == "":
        return None
    try:
        return int(value)
    except ValueError:
        pass
    try:
        return float(value)
    except ValueError:
        pass
    return value


def group_rows(rows: list[dict]) -> list[dict]:
    """Group rows by expedition, then sort everything newest-first.

    Returns a list where each item is either:
      {"type": "day trip", "display_date": ..., "sort_date": ..., "canyon": ..., ...}
      {"type": "expedition", "name": ..., "display_date": ..., "sort_date": ...,
       "canyons": [{...}, ...]}

    Expedition sort_date is the earliest sort_date among its canyons.
    Canyon order within an expedition preserves sheet order.
    """
    # Collect expeditions in first-seen order, preserving canyon order within each.
    expeditions: dict[str, dict] = {}
    result: list[dict] = []

    for row in rows:
        exp_name = row.pop("expedition")
        if exp_name:
            if exp_name not in expeditions:
                entry = {
                    "type": "expedition",
                    "name": exp_name,
                    "display_date": row["display_date"],
                    "sort_date": row["sort_date"],
                    "canyons": [],
                }
                expeditions[exp_name] = entry
                result.append(entry)
            else:
                # Keep the earliest sort_date for the expedition header
                entry = expeditions[exp_name]
                if row["sort_date"] < entry["sort_date"]:
                    entry["sort_date"] = row["sort_date"]
                    entry["display_date"] = row["display_date"]
            expeditions[exp_name]["canyons"].append(row)
        else:
            row["type"] = "day trip"
            result.append(row)

    result.sort(key=lambda r: r["sort_date"], reverse=True)
    return result


def main() -> None:
    print(f"Fetching {URL} ...")
    with urllib.request.urlopen(URL) as resp:
        content = resp.read().decode("utf-8")

    reader = csv.DictReader(io.StringIO(content))
    rows = []
    for row in reader:
        r = {k: coerce(v) for k, v in row.items()}
        display_date, sort_date = format_dates(r.pop("date"))
        r["display_date"] = display_date
        r["sort_date"] = sort_date
        rows.append(r)

    grouped = group_rows(rows)

    OUTPUT.write_text(json.dumps(grouped, indent=2))
    print(f"Wrote {len(grouped)} entries ({len(rows)} canyons) to {OUTPUT}")


if __name__ == "__main__":
    main()
